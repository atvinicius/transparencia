---
interface Props {
  label: string;
  value: string | number | boolean;
  context?: string;
  sourceName: string;
  sourceUrl: string;
}

const { label, value, context, sourceName, sourceUrl } = Astro.props;
---

<div class="py-3 border-b border-gray-100 last:border-0">
  <div class="flex items-baseline justify-between gap-4">
    <span class="text-sm text-gray-600">{label}</span>
    <span class="font-semibold text-lg tabular-nums">
      {typeof value === "boolean" ? (value ? "Sim" : "Não") : value}
    </span>
  </div>
  {context && (
    <p class="text-xs text-gray-400 mt-0.5">{context}</p>
  )}
  <a
    href={sourceUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1 text-xs text-emerald-600 hover:underline mt-1"
  >
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
    </svg>
    {sourceName}
  </a>
</div>
