---
import Base from "../layouts/Base.astro";
import CandidateCard from "../components/CandidateCard.astro";
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";

const dataDir = join(process.cwd(), "..", "data", "output");
const indexPath = join(dataDir, "candidates-index.json");
const metadataPath = join(dataDir, "metadata.json");

interface CandidateIndex {
  slug: string;
  name: string;
  shortName: string;
  party: string;
  state: string;
  photoUrl?: string;
}

interface Metadata {
  lastRun: string;
  candidateCount: number;
  sources: Array<{ name: string; status: string; recordCount: number }>;
}

let candidates: CandidateIndex[] = [];
let metadata: Metadata | null = null;

if (existsSync(indexPath)) {
  candidates = JSON.parse(readFileSync(indexPath, "utf-8"));
}
if (existsSync(metadataPath)) {
  metadata = JSON.parse(readFileSync(metadataPath, "utf-8"));
}

// Sort by name
candidates.sort((a, b) => a.shortName.localeCompare(b.shortName, "pt-BR"));
---

<Base title="Candidatos">
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Transparência</h1>
    <p class="text-gray-600 text-lg">
      Dados factuais e verificáveis sobre representantes e candidatos às eleições brasileiras.
    </p>
    <p class="text-gray-500 text-sm mt-2">
      Todas as informações são obtidas automaticamente de fontes oficiais. Sem opiniões, sem rankings — apenas fatos.
    </p>
    {metadata && (
      <p class="text-xs text-gray-400 mt-2">
        Última atualização: {new Date(metadata.lastRun).toLocaleDateString("pt-BR")} —
        {metadata.candidateCount} perfis —
        {metadata.sources.map(s => s.name).join(", ")}
      </p>
    )}
  </div>

  {candidates.length === 0 ? (
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
      <p class="text-yellow-800">
        Nenhum dado disponível ainda. Execute o pipeline de dados:
        <code class="bg-yellow-100 px-2 py-1 rounded text-sm">pnpm pipeline --limit 5</code>
      </p>
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {candidates.map((c) => (
        <CandidateCard
          slug={c.slug}
          name={c.name}
          shortName={c.shortName}
          party={c.party}
          state={c.state}
          photoUrl={c.photoUrl}
        />
      ))}
    </div>
  )}
</Base>
